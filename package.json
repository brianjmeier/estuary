{
  "name": "agenator",
  "version": "0.1.0",
  "description": "AI Agent Orchestration TUI with Linear Integration and JJ Workspace Isolation",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "agenator": "dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.tsx --outdir dist --target node",
    "dev": "bun --watch src/cli.tsx",
    "start": "bun dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "llm",
    "agent",
    "tui",
    "cli",
    "terminal",
    "linear",
    "jujutsu",
    "jj"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "graphql": "^16.12.0",
    "graphql-request": "^7.4.0",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.7.2"
  }
}
